# ─── Zaujain Environment Variables ──────────────────────────────────────────
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.

# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ─── Supabase ─────────────────────────────────────────────────────────────────
# Found in: Supabase Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service role key — NEVER expose this to the client
# Only used in server-side code (admin operations)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ─── Cloudinary ───────────────────────────────────────────────────────────────
# Found in: Cloudinary Dashboard → Settings → Access Keys
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your-cloud-name
NEXT_PUBLIC_CLOUDINARY_API_KEY=your-api-key
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=zaujain_unsigned

# API secret — NEVER expose this to the client
CLOUDINARY_API_SECRET=your-api-secret
